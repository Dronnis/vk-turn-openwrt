#!/bin/sh /etc/rc.common

USE_PROCD=1
START=90
STOP=10
SERVICE_DAEMONIZE=1
SERVICE_WRITE_PID=1

BINARY="/usr/bin/vk-turn-client"
CONFIG="vk-turn-client"

load_config() {
	config_load "$CONFIG"
	config_get PEER_ADDRESS main peer_address ""
	config_get PEER_PORT main peer_port ""
	config_get LISTEN_ADDRESS main listen_address ""
	config_get LISTEN_PORT main listen_port ""
	config_get VK_LINK main vk_link ""
	config_get SESSION_ID main session_id ""
	config_get TURN_CONNECTION main turn_connection ""
	config_get TURN_ADDRESS main turn_address ""
	config_get TURN_PORT main turn_port ""
	config_get_bool USE_UDP main use_udp 0
	config_get_bool USE_V1 main use_v1 0
	config_get_bool NO_DTLS main no_dtls 0
	config_get_bool USE_WB main use_wb 0
}

validate_config() {
	[ -z "$PEER_ADDRESS" ] && { echo "ERROR: peer_address required"; return 1; }
	[ -z "$PEER_PORT" ] && { echo "ERROR: peer_port required"; return 1; }
	[ -z "$LISTEN_ADDRESS" ] && { echo "ERROR: listen_address required"; return 1; }
	[ -z "$LISTEN_PORT" ] && { echo "ERROR: listen_port required"; return 1; }
	
	# Требуется vk_link ИЛИ use_wb
	if [ -z "$VK_LINK" ] && [ "$USE_WB" != "1" ]; then
		echo "ERROR: vk_link or use_wb is required"
		return 1
	fi
	
	# Конфликт: use_wb + vk_link
	if [ "$USE_WB" = "1" ] && [ -n "$VK_LINK" ]; then
		echo "ERROR: use_wb cannot be used with vk_link"
		return 1
	fi
	return 0
}

build_args() {
	local args="-peer ${PEER_ADDRESS}:${PEER_PORT} -listen ${LISTEN_ADDRESS}:${LISTEN_PORT}"
	
	[ -n "$VK_LINK" ] && args="$args -vk-link '$VK_LINK'"
	[ -n "$SESSION_ID" ] && args="$args -session-id '$SESSION_ID'"
	[ -n "$TURN_CONNECTION" ] && args="$args -n '$TURN_CONNECTION'"
	[ -n "$TURN_ADDRESS" ] && args="$args -turn '$TURN_ADDRESS'"
	[ -n "$TURN_PORT" ] && args="$args -port '$TURN_PORT'"
	
	[ "$USE_UDP" = "1" ] && args="$args -udp"
	[ "$USE_V1" = "1" ] && args="$args -v1"
	[ "$NO_DTLS" = "1" ] && args="$args -no-dtls"
	[ "$USE_WB" = "1" ] && args="$args -wb"
	
	echo "$args"
}

start_service() {
	load_config
	validate_config || return 1
	
	procd_open_instance
	procd_set_param command "$BINARY" $(build_args)
	procd_set_param respawn
	procd_set_param respawn_threshold 30
	procd_set_param respawn_timeout 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/vk-turn-client.pid
	procd_close_instance
}

stop_service() {
	procd_kill "vk-turn-client" 2>/dev/null
	rm -f /var/run/vk-turn-client.pid
}

reload_service() {
	stop_service
	sleep 1
	start_service
}

boot() {
	sleep 5
	start_service
}